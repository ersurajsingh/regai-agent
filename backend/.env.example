# ============================================================
# RegAI Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Google Gemini / ADK ────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-flash-latest

# ── Google Cloud ───────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your_gcp_project_id

# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
# Create a free cluster at: https://cloud.mongodb.com
# Add your IP to Network Access, then get the connection string.
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/regai?retryWrites=true&w=majority
MONGODB_DB_NAME=regai

# ── Arize Phoenix Observability ────────────────────────────────────────────────
# Get your API key at: https://app.phoenix.arize.com → Settings → API Keys
# PHOENIX_HOST is used by the Phoenix MCP server and phoenix-cli.
PHOENIX_HOST=https://app.phoenix.arize.com
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/your_project_slug
PHOENIX_API_KEY=your_phoenix_api_key_here
PHOENIX_PROJECT_NAME=regai-compliance

# ── Arize AX (optional) ────────────────────────────────────────────────────────
ARIZE_SPACE_ID=your_arize_space_id
ARIZE_API_KEY=your_arize_api_key
ARIZE_PROJECT_NAME=regai-agent

# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change_this_to_a_long_random_string
SESSION_EXPIRE_HOURS=24
MAX_UPLOAD_SIZE_MB=10
ALLOWED_ORIGINS=["http://localhost:3000"]
